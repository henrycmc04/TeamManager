<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:id="root"
            prefHeight="800.0"
            prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="progetto.applicazione.controller.RegistrazioneController">

    <top>
        <VBox>
            <HBox alignment="CENTER" spacing="10" styleClass="header">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>
                <Label text="TeamManager" styleClass="header-title"/>
            </HBox>
            <HBox alignment="TOP_LEFT" spacing="10" style="-fx-padding: 10 0 10 20;">
                <Button fx:id="backButton"
                        onAction="#back"
                        text="◀ Indietro"
                        styleClass="back-button"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="15" styleClass="login-card">

            <TextField fx:id="nome"
                       promptText="Nome"
                       prefWidth="250"
                       prefHeight="35"/>

            <TextField fx:id="cognome"
                       promptText="Cognome"
                       prefWidth="250"
                       prefHeight="35"/>

            <TextField fx:id="codiceFiscale"
                       promptText="Codice Fiscale"
                       prefWidth="250"
                       prefHeight="35"/>

            <TextField fx:id="email"
                       promptText="Email"
                       prefWidth="250"
                       prefHeight="35"/>

            <PasswordField fx:id="pwd"
                           promptText="Password"
                           prefWidth="250"
                           prefHeight="35"/>

            <PasswordField fx:id="confPwd"
                           promptText="Conferma Password"
                           prefWidth="250"
                           prefHeight="35"/>

            <Button fx:id="registratiButton"
                    onAction="#handleRegistrazione"
                    text="Registrati"
                    prefWidth="250"
                    prefHeight="35"/>

            <Label fx:id="errorLabel"
                   text=""
                   visible="false"
                   managed="false"
                   wrapText="true"
                   styleClass="feedback-label">
                <VBox.margin>
                    <Insets top="10"/>
                </VBox.margin>
            </Label>

        </VBox>
    </center>

</BorderPane>
