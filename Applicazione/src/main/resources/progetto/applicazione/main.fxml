<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:id="root"
            prefHeight="800.0"
            prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="progetto.applicazione.controller.MainController">

    <top>
        <HBox alignment="CENTER" spacing="10" styleClass="header">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="TeamManager" styleClass="header-title"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="25" styleClass="login-card">
            <padding>
                <Insets top="50" bottom="50"/>
            </padding>
            <Button fx:id="accediButton"
                    onAction="#login"
                    text="Accedi"
                    prefWidth="200"/>

            <Button fx:id="registratiButton"
                    onAction="#registrazione"
                    text="Registrati"
                    prefWidth="200"/>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="15" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="50" bottom="50"/>
            </padding>

            <Button fx:id="initDbButton"
                    onAction="#handleInitDatabase"
                    text="Inizializza DB"
                    styleClass="db-button"/>

            <Label fx:id="initDbResultLabel"
                   text=""
                   wrapText="true"
                   visible="false"
                   managed="false" 
                   styleClass="feedback-label">
                <VBox.margin>
                    <Insets top="10"/>
                </VBox.margin>
            </Label>

        </VBox>
    </bottom>

</BorderPane>
