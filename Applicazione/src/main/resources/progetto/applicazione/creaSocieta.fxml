<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:id="root"
            prefHeight="800.0"
            prefWidth="1280.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="progetto.applicazione.controller.CreaSocietaController">

    <top>
        <VBox>
            <HBox alignment="CENTER" spacing="10" styleClass="header">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="Creazione società" styleClass="header-title"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="15" styleClass="login-card">

            <TextField fx:id="nomeSocieta"
                       promptText="Nome società"
                       prefWidth="250"
                       prefHeight="35"/>

            <TextField fx:id="partitaIva"
                       promptText="Partita IVA"
                       prefWidth="250"
                       prefHeight="35"/>

            <Button fx:id="creaSocietaButton"
                    onAction="#handleCreaSocieta"
                    text="Crea società"
                    prefWidth="250"
                    prefHeight="35"/>

            <Label fx:id="errorLabel"
                   text=""
                   visible="false"
                   managed="false"
                   wrapText="true"
                   styleClass="feedback-label">
                <VBox.margin>
                    <Insets top="10"/>
                </VBox.margin>
            </Label>

        </VBox>
    </center>

</BorderPane>
